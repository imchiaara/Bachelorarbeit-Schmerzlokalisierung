                                                                            <upper_included>true</upper_included>
                                                                            <lower_unbounded>false</lower_unbounded>
                                                                            <upper_unbounded>false</upper_unbounded>
                                                                            <lower>1</lower>
                                                                            <upper>1</upper>
                                                                        </occurrences>
                                                                        <node_id></node_id>
                                                                        <item xsi:type="C_STRING">
                                                                            <list>Painted region</list>
                                                                        </item>
                                                                    </children>
