                                                                    <type>String</type>
                                                                    <item xsi:type="C_STRING">
                                                                        <pattern>openEHR-EHR-CLUSTER\.symptom_sign(-[a-zA-Z0-9_]+)*\.v1|openEHR-EHR-CLUSTER\.symptom_sign(-[a-zA-Z0-9_]+)*\.v2</pattern>
                                                                    </item>
