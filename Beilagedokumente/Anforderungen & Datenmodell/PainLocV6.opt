                                                                <archetype_id>
                                                                    <value>openEHR-EHR-CLUSTER.anatomical_location_circle.v1</value>
                                                                </archetype_id>
                                                                <term_definitions code="cm">
                                                                    <items id="text">%</items>
                                                                    <items id="description">centimeter</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0000">
                                                                    <items id="text">Segment overlap</items>
                                                                    <items id="description">A physical site on or within the human body that is described in terms of the direction, and optionally the distance, of the site from a central landmark.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0023">
                                                                    <items id="text">Description</items>
                                                                    <items id="description">Narrative description that can be used to further refine and support structured data about the circular location.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0054">
                                                                    <items id="text">Multimedia representation</items>
                                                                    <items id="description">Image or other media used to support identification of the location on the body.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0061">
                                                                    <items id="text">Circular direction</items>
                                                                    <items id="description">Identification of the angle of the direction to the physical site relative to the reference direction, either as the position of an hour hand on a clockface or number of degrees.</items>
                                                                    <items id="comment">For example: the position of haemorrhoids in the anal canal are commonly described at 3 o'clock, 7 o'clock and 11 o'clock. In this situation the perineum is situated at 12 o'clock with patient in the lithotomy position, and regarded as the reference direction. For degrees, positive values are angles in the clockwise direction, while negative values are in the anti-clockwise direction.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0065">
                                                                    <items id="text">Reference direction</items>
                                                                    <items id="description">Identification of a single direction which represents the 12 o'clock or 0° position on an imaginary circle superimposed over the body site, as seen by the examiner.</items>
                                                                    <items id="comment">For example: the reference axis is commonly towards the head if examining the breast or detail on a skin lesion; towards the perineum if examining the anus in the lithotomy position; or towards the anterior humeral line if examining the humerus.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0067">
                                                                    <items id="text">One o'clock</items>
                                                                    <items id="description">The body site is located at the one o'clock position relative to the identified reference point.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0068">
                                                                    <items id="text">Two o'clock</items>
                                                                    <items id="description">The body site is located at the two o'clock position relative to the identified reference point.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0069">
                                                                    <items id="text">Three o'clock</items>
                                                                    <items id="description">The body site is located at the three o'clock position relative to the identified reference point.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0070">
                                                                    <items id="text">Four o'clock</items>
                                                                    <items id="description">The body site is located at the four o'clock position relative to the identified reference point.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0071">
                                                                    <items id="text">Five o'clock</items>
                                                                    <items id="description">The body site is located at the five o'clock position relative to the identified reference point.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0072">
                                                                    <items id="text">Six o'clock</items>
                                                                    <items id="description">The body site is located at the six o'clock position relative to the identified reference point.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0073">
                                                                    <items id="text">Seven o'clock</items>
                                                                    <items id="description">The body site is located at the seven o'clock position relative to the identified reference point.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0074">
                                                                    <items id="text">Eight o'clock</items>
                                                                    <items id="description">The body site is located at the eight o'clock position relative to the identified reference point.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0075">
                                                                    <items id="text">Nine o'clock</items>
                                                                    <items id="description">The body site is located at the nine o'clock position relative to the identified reference point.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0076">
                                                                    <items id="text">Ten o'clock</items>
                                                                    <items id="description">The body site is located at the ten o'clock position relative to the identified reference point.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0077">
                                                                    <items id="text">Eleven o'clock</items>
                                                                    <items id="description">The body site is located at the eleven o'clock position relative to the identified reference point.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0078">
                                                                    <items id="text">Twelve o'clock</items>
                                                                    <items id="description">The body site is located at the twelve o'clock position relative to the identified reference point.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0079">
                                                                    <items id="text">Centre landmark</items>
                                                                    <items id="description">Identified body site used as a reference point for centre of the imaginary circle.</items>
                                                                    <items id="comment">For example: the nipple when examining a breast; or the anus when examining haemorrhoids.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0080">
                                                                    <items id="text">Overlap percent</items>
                                                                    <items id="description">Distance of location from the identified central landmark.</items>
                                                                </term_definitions>
                                                            </children>
