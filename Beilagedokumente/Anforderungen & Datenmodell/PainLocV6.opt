                                                                            <upper>1</upper>
                                                                        </occurrences>
                                                                        <node_id></node_id>
                                                                        <item xsi:type="C_STRING">
                                                                            <list>Myotomal mapping</list>
                                                                        </item>
                                                                    </children>
