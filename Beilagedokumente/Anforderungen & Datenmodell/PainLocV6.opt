                                                        <archetype_id>
                                                            <value>openEHR-EHR-CLUSTER.severity_rating_scale.v0</value>
                                                        </archetype_id>
                                                        <term_definitions code="at0000">
                                                            <items id="text">NRS score</items>
                                                            <items id="description">A numeric rating scale to quantify a subjective evaluation of the severity of a symptom/sign/problem/issue.</items>
                                                        </term_definitions>
                                                        <term_definitions code="at0003">
                                                            <items id="text">Numeric rating scale 0-10</items>
                                                            <items id="description">Numeric rating scale 0 to 10.</items>
                                                            <items id="comment">Name of the element will always be renamed to the specific question in the template. </items>
                                                        </term_definitions>
                                                        <term_definitions code="at0004">
                                                            <items id="text">0</items>
                                                            <items id="description"></items>
                                                        </term_definitions>
                                                        <term_definitions code="at0005">
                                                            <items id="text">1</items>
                                                            <items id="description"></items>
                                                        </term_definitions>
                                                        <term_definitions code="at0006">
                                                            <items id="text">2</items>
                                                            <items id="description"></items>
                                                        </term_definitions>
                                                        <term_definitions code="at0007">
                                                            <items id="text">3</items>
                                                            <items id="description"></items>
                                                        </term_definitions>
                                                        <term_definitions code="at0008">
                                                            <items id="text">4</items>
                                                            <items id="description"></items>
                                                        </term_definitions>
                                                        <term_definitions code="at0009">
                                                            <items id="text">5</items>
                                                            <items id="description"></items>
                                                        </term_definitions>
                                                        <term_definitions code="at0010">
                                                            <items id="text">6</items>
                                                            <items id="description"></items>
                                                        </term_definitions>
                                                        <term_definitions code="at0011">
                                                            <items id="text">7</items>
                                                            <items id="description"></items>
                                                        </term_definitions>
                                                        <term_definitions code="at0012">
                                                            <items id="text">8</items>
                                                            <items id="description"></items>
                                                        </term_definitions>
                                                        <term_definitions code="at0013">
                                                            <items id="text">9</items>
                                                            <items id="description"></items>
                                                        </term_definitions>
                                                        <term_definitions code="at0014">
                                                            <items id="text">10</items>
                                                            <items id="description"></items>
                                                        </term_definitions>
                                                        <term_definitions code="at0015">
                                                            <items id="text">Comment</items>
                                                            <items id="description">Additional narrative about the severity rating not captured in other fields.</items>
                                                        </term_definitions>
                                                        <term_definitions code="at0016">
                                                            <items id="text">Numeric rating scale 0-20</items>
                                                            <items id="description">Numeric rating scale 0 to 20.</items>
                                                            <items id="comment">Name of the element will always be renamed to the specific question in the template. </items>
                                                        </term_definitions>
                                                        <term_definitions code="at0017">
                                                            <items id="text">Pain intensity</items>
                                                            <items id="description">Numeric rating scale 0 to 100.</items>
                                                            <items id="comment">Name of the element will always be renamed to the specific question in the template. </items>
                                                        </term_definitions>
                                                        <term_definitions code="at0020">
                                                            <items id="text">Numeric rating scale</items>
                                                            <items id="description">Unconstrained numeric rating scale.</items>
                                                            <items id="comment">Name of the element will always be renamed to the specific question in the template. </items>
                                                        </term_definitions>
                                                        <term_definitions code="at0021">
                                                            <items id="text">Visual analogue scale</items>
                                                            <items id="description">Visual analogue scale 0 to 100.</items>
                                                            <items id="comment">Name of the element will always be renamed to the specific question in the template. </items>
                                                        </term_definitions>
                                                    </children>
