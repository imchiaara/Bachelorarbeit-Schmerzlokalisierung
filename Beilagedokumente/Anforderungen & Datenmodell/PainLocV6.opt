                                                            <upper_unbounded>true</upper_unbounded>
                                                            <lower>0</lower>
                                                        </occurrences>
                                                        <node_id>at0063</node_id>
                                                        <includes>
                                                            <string_expression>archetype_id/value matches {/openEHR-EHR-CLUSTER\.symptom_sign(-[a-zA-Z0-9_]+)*\.v1|openEHR-EHR-CLUSTER\.symptom_sign(-[a-zA-Z0-9_]+)*\.v2/}</string_expression>
                                                            <expression xsi:type="EXPR_BINARY_OPERATOR">
                                                                <type>Boolean</type>
                                                                <operator>2007</operator>
                                                                <precedence_overridden>false</precedence_overridden>
                                                                <left_operand xsi:type="EXPR_LEAF">
                                                                    <type>String</type>
                                                                    <item xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema">archetype_id/value</item>
                                                                    <reference_type>attribute</reference_type>
                                                                </left_operand>
